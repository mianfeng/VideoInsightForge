{
  "name": "Video Quick Eval",
  "version": "0.1.0",
  "manifest_version": 3,
  "description": "Trigger VideoInsightForge from the current tab.",
  "action": {
    "default_title": "Video Quick Eval",
    "default_popup": "popup.html"
  },
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["tabs", "activeTab", "storage"],
  "host_permissions": [
    "http://127.0.0.1:8732/*",
    "http://localhost:8732/*"
  ]
}
