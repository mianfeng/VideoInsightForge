{
  "llm": {
    "provider": "openai",
    "api_key": "your-api-key-here",
    "base_url": "https://api.openai.com/v1",
    "model": "gpt-4o-mini",
    "temperature": 0.3,
    "max_tokens": 12000,
    "long_input_tokens": 6000,
    "chunk_tokens": 1800,
    "chunk_overlap_tokens": 200
  },
  "transcribe": {
    "model_size": "tiny",
    "cpu_threads": 4,
    "auto_optimize": true
  },
  "pipeline": {
    "enable_parallel": true,
    "output_language": "zh"
  }
}
